  m_Script: {fileID: 11500000, guid: 460fd8ec36f2f8a46a69fba16c784a23, type: 3}
  m_Name: New Tutorial Set
  m_EditorClassIdentifier: Assembly-CSharp::RCCom.UI.TutorialSet
  pages:
  - topic: "\uD0C0\uC6CC \uAC74\uC124"
    description: "\uC88C\uCE21 \uD558\uB2E8\uC5D0\uC11C \uACE8\uB4DC\uB97C \uC9C0\uBD88\uD558\uC5EC
      \uD0C0\uC6CC\uB97C \uAC74\uC124\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\uD0C0\uC6CC\uB294
      \uC138 \uC885\uB958\uAC00 \uC788\uC73C\uBA70, \uAC01\uAC01 \uACF5\uACA9, \uC2A4\uD0AC,
      \uD30C\uC6CC(\uC804\uC5ED)\uC785\uB2C8\uB2E4.\n\uACF5\uACA9\uC740 \uD3EC\uD0D1,
      \uC2A4\uD0AC\uC740 \uBC94\uC704 \uB0B4\uC5D0 \uBC84\uD504\uC640 \uB514\uBC84\uD504,
      \uD30C\uC6CC\uB294 \uBAA8\uB4E0 \uD3EC\uD0D1\uC5D0\n\uC601\uD5A5\uC744 \uBBF8\uCE69\uB2C8\uB2E4."
    image: {fileID: -4425806449190991492, guid: 4dcda599efe4de64a8f8487e08dfb75b, type: 3}
  - topic: "\uACF5\uACA9/\uC2A4\uD0AC"
    description: "\uD50C\uB808\uC774\uC5B4\uB294 \uC801\uC5D0 \uC77C\uC815 \uAC70\uB9AC
      \uC811\uADFC\uD558\uBA74 \uC790\uB3D9\uC73C\uB85C \uACF5\uACA9\uD569\uB2C8\uB2E4.\n\uC88C\uCE21
      \uC0C1\uB2E8\uC758 \uC2A4\uD0AC \uAC8C\uC774\uC9C0 \uBC14\uAC00 \uB2E4 \uCC28\uBA74(\uCFE8\uD0C0\uC784\uC81C),
      \n\uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD574 \uBE60\uB974\uAC8C 4\uBC88 \uACF5\uACA9\uD569\uB2C8\uB2E4.\nSpace
      \uD0A4\uB97C \uD1B5\uD574 \uC2A4\uD0AC\uC744 \uC0AC\uC6A9\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    image: {fileID: 5545074057135662542, guid: 7f8ab3d4cd966e048aa117b361c67c2f, type: 3}
  - topic: "\uB808\uBCA8\uC5C5 \uD2B9\uC804"
    description: "\uB808\uBCA8\uC5C5\uC2DC \uB808\uBCA8\uC5C5 \uD2B9\uC804\uC744
      \uC120\uD0DD\uD558\uB294 \uAC83\uC774 \uAC00\uB2A5\uD574\uC9D1\uB2C8\uB2E4.\n\uC774\uB54C
      \uC804\uC5ED \uBC84\uD504\uB098 \uCD94\uAC00\uC801\uC778 \uD0C0\uC6CC\uB4E4\uC744
      \uD574\uAE08\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\uCD94\uAC00 \uD574\uAE08
      \uD0C0\uC6CC\uB4E4\uC740 \uBE44\uC2FC \uACBD\uC6B0\uAC00 \uB9CE\uC73C\uB2C8
      \uC804\uB7B5\uC801\uC778 \uC120\uD0DD\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
    image: {fileID: -3428672953092550586, guid: 768a1c92f9fc7c9498c673a022240d89, type: 3}
  - topic: "\uD0C0\uC6CC \uC218 \uC81C\uD55C"
    description: "\uAC74\uC124 \uAC00\uB2A5\uD55C \uD0C0\uC6CC\uC758 \uC218\uB294
      \uD55C\uACC4\uC120\uC774 \uC788\uC2B5\uB2C8\uB2E4.\n\uB808\uBCA8\uC5C5 \uD2B9\uC804\uC73C\uB85C
      \uC774 \uD55C\uACC4\uC120\uC744 \uCD94\uAC00\uB85C \uD655\uC7A5\uD560 \uC218
      \uC788\uC2B5\uB2C8\uB2E4."
    image: {fileID: 546169645079054871, guid: 1962102ce1379df499462997ea41381f, type: 3}
  - topic: "\uAC74\uC124 \uBAA8\uB4DC"
    description: "\uC624\uB978\uCABD \uB9C8\uC6B0\uC2A4 \uD074\uB9AD\uC2DC \uD0C0\uC6CC
      \uAC74\uC124 \uBAA8\uB4DC\uAC00 \uD480\uB9BD\uB2C8\uB2E4.\n\uB610\uD55C, \uC774\uBBF8
      \uAC74\uC124\uD55C \uD3EC\uD0D1\uC5D0 Alt+\uC67C\uCABD \uD074\uB9AD\uC2DC \uD3EC\uD0D1\uC744
      \uC81C\uAC70\uD569\uB2C8\uB2E4.\n\uC774\uB54C \uD3EC\uD0D1 \uAC00\uACA9\uC758
      75%\uB97C \uB0B4\uC57C \uD558\uB2C8 \uC2E0\uC911\uD558\uAC8C \uACB0\uC815\uD569\uC2DC\uB2E4."
    image: {fileID: 4127193398807295954, guid: f2091b9bba915a347b731d6cd698f65d, type: 3}
  - topic: "\uD328\uBC30 \uC870\uAC74"
    description: "\uC801\uACFC \uC811\uCD09\uD558\uC5EC \uD50C\uB808\uC774\uC5B4\uC758
      HP\uAC00 0 \uC774\uD558\uAC00 \uB418\uAC70\uB098,\n\uD639\uC740 \uC801\uC744
      \uB9C8\uC9C0\uB9C9 \uB7A0\uB9AC \uD3EC\uC778\uD2B8\uAE4C\uC9C0 \uC9C0\uC18D\uC801\uC73C\uB85C
      \uB4E4\uC5EC\uBCF4\uB0B4\n\uAE30\uC9C0\uC758 HP\uAC00 0 \uC774\uD558\uAC00
      \uB418\uBA74 \uD328\uBC30\uD569\uB2C8\uB2E4."
    image: {fileID: -7348694548276590456, guid: 38e8e082364dd31458128f50229822db, type: 3}
